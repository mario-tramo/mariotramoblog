# =====================================================================
# Trm Sport — environment variables
# =====================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.

# ----- Public (REQUIRED, exposed to the browser) ----------------------

# Canonical site URL — used everywhere as BASE_URL.
NEXT_PUBLIC_BASE_URL="https://trmsport.com"

# Sanity CMS (public, safe).
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-12-01"

# Titolare del trattamento (used in Privacy/Cookie Policy seed).
NEXT_PUBLIC_CONTACT_NAME="Trm Sport"
NEXT_PUBLIC_CONTACT_ADDRESS="Via dello Sport, 1 — 00100 Roma (RM)"
NEXT_PUBLIC_CONTACT_EMAIL="info@trmsport.com"
NEXT_PUBLIC_CONTACT_PEC=""

# Google Search Console verification token (optional).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ----- Sanity (server-only, secret) -----------------------------------

# Read-token used by Next.js to query Sanity (Viewer permission).
SANITY_API_READ_TOKEN=""

# Write-token used by the cron publish job (Editor permission).
SANITY_API_WRITE_TOKEN=""

# ----- Storage (server-only, secret) ----------------------------------

# Upstash Redis (EU region recommended for GDPR data residency).
UPSTASH_REDIS_REST_URL="https://<region>-<id>.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# ----- External integrations (server-only, secret) --------------------

# football-data.org API key for standings/results.
FOOTBALL_DATA_API_KEY=""

# ----- Internal endpoints (server-only, secret) -----------------------

# Authorization on /api/revalidate  (>= 32 hex chars recommended).
# Generate: openssl rand -hex 32
REVALIDATE_SECRET=""

# Authorization on /api/cron/publish-scheduled (>= 32 hex chars recommended).
# Generate: openssl rand -hex 32
CRON_SECRET=""
